{"app": {"bundleName": "com.wecheckin.app", "vendor": "wecheckin", "versionCode": 1000001, "versionName": "1.0.0", "icon": "$media:icon", "label": "$string:app_name"}, "moduleConfig": {"moduleName": "WeCheckin", "moduleType": "entry", "description": "$string:module_description", "mainElement": ".MainAbility", "deviceTypes": ["phone"], "deliveryWithInstall": true, "installationFree": false, "pages": [{"name": "pages/index/index", "style": {"navigationBarTitleText": "首页"}}, {"name": "pages/news/news_index", "style": {"navigationBarTitleText": "通知"}}, {"name": "pages/enroll/enroll_index", "style": {"navigationBarTitleText": "打卡任务"}}, {"name": "pages/enroll/my_user_list", "style": {"navigationBarTitleText": "我的打卡"}}, {"name": "pages/my/my_index", "style": {"navigationBarTitleText": "个人中心"}}], "abilities": [{"name": ".MainAbility", "srcEntry": "./ets/MainAbility/MainAbility.ts", "description": "$string:mainability_description", "icon": "$media:icon", "label": "$string:mainability_label", "startWindowIcon": "$media:icon", "startWindowBackground": "$color:white", "visible": true, "launchType": "standard"}], "requestPermissions": [{"name": "ohos.permission.INTERNET", "reason": "$string:internet_permission_reason"}, {"name": "ohos.permission.CAMERA", "reason": "$string:camera_permission_reason"}]}}